#include <stdio.h>

int main() {
    int i;

    printf("Demonstrating continue:\n");
    for(i = 1; i <= 5; i++) {
        if(i == 3)
            continue;   // skips when i = 3
        printf("%d ", i);
    }

    printf("\nDemonstrating break:\n");
    for(i = 1; i <= 5; i++) {
        if(i == 3)
            break;   // stops loop when i = 3
        printf("%d ", i);
    }

    return 0;
}
